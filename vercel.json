{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "cd frontend && npm ci",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://kings-analytics-backend.fly.dev/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
