# Canvas LMS Configuration
# Your Canvas instance URL (e.g. https://yourschool.instructure.com)
CANVAS_API_URL=https://kings.instructure.com

# Canvas API token — generate from Canvas > Account > Settings > New Access Token
CANVAS_API_TOKEN=

# Database — overridden by docker-compose for local dev
# For production (Supabase + Render): postgresql+asyncpg://user:pass@host:5432/db?ssl=require
DATABASE_URL=postgresql+asyncpg://kings:kings@db:5432/kings_analytics

# Sync interval in hours (default: 24)
SYNC_INTERVAL_HOURS=24

# CORS allowed origins (comma-separated)
# For production set to your Vercel URL(s): https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Canvas course ID whitelist (comma-separated). Only these courses will be synced.
# Leave empty to sync all courses the API token has access to.
CANVAS_COURSE_WHITELIST=
